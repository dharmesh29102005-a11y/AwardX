{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    },
    "api/cron/round-scheduler.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/round-scheduler",
      "schedule": "* * * * *"
    }
  ]
}
