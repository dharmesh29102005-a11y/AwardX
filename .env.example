VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_STORAGE_BUCKET_AVATARS=media
VITE_STORAGE_BUCKET_SUBMISSIONS=media
VITE_STORAGE_BUCKET_PROGRAM_ASSETS=media

# Server-side Supabase (service role — bypasses RLS)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
VITE_SITE_URL=http://localhost:3000
# Leave empty in local dev so API calls use the Vite proxy (same origin as the dev server).
# Set in production to your deployed Express/API base URL.
VITE_BACKEND_URL=
# Must match the Express server PORT (default 5001). macOS often uses 5000 for AirPlay.
VITE_BACKEND_PROXY_TARGET=http://localhost:5001
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=AwardX <no-reply@yourdomain.com>
