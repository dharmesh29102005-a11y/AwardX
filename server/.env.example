# Server
PORT=5001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email — per-organization Resend keys are stored in Supabase (Settings → Integrations).
# Do not rely on server .env for tenant email; optional values below are legacy only.
# RESEND_API_KEY=
# RESEND_FROM=

# Razorpay OAuth (Partner Dashboard application)
RAZORPAY_OAUTH_CLIENT_ID=
RAZORPAY_OAUTH_CLIENT_SECRET=
# Optional override; default is {SITE_URL}/api/integrations/razorpay/oauth/callback
RAZORPAY_OAUTH_REDIRECT_URI=
# test | live
RAZORPAY_OAUTH_MODE=test

# Redis cache
REDIS_ENABLED=false
REDIS_URL=
REDIS_TOKEN=
REDIS_USERNAME=default
REDIS_NAMESPACE=awardx
